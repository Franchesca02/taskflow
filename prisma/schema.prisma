generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  
}

model Column {
  id        String   @id @default(cuid())
  title     String
  order     Int
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([order])
  @@map("columns")
}

model Task {
  id          String   @id @default(cuid())
  content     String
  description String?
  columnId    String
  column      Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([columnId, order])
  @@map("tasks")
}